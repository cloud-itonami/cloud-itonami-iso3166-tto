#:culture{:id "tto.dish.doubles", :name "Doubles", :country "TTO", :kind :dish, :summary "Caribbean street food of curried chickpeas served on two fried flatbreads, part of Indo-Trinidadian cuisine and credited to Emamool Deen in 1936.", :url "https://en.wikipedia.org/wiki/Doubles_(food)", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "tto.dish.pelau", :name "Pelau", :country "TTO", :kind :dish, :summary "Traditional West Indies rice dish that originated in Trinidad when Indian indentured servants shared pilaf preparation methods with African slaves, who adapted it with caramelization techniques and local Caribbean ingredients.", :url "https://en.wikipedia.org/wiki/Pelau", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "tto.dish.callaloo", :name "Callaloo", :country "TTO", :kind :dish, :summary "One of the national dishes of Trinidad and Tobago (shared with Dominica); Trinidadians prepare it with taro/dasheen bush and okra with coconut milk, distinct from Jamaica's amaranth-based version.", :url "https://en.wikipedia.org/wiki/Callaloo", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "tto.dish.bake-and-shark", :name "Bake and shark", :country "TTO", :kind :dish, :summary "Traditional fast food dish of Trinidadian cuisine, prepared with fried flatbread, shark meat, and additional ingredients; particularly associated with Maracas Beach.", :url "https://en.wikipedia.org/wiki/Bake_and_shark", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "tto.product.angostura-bitters", :name "Angostura bitters", :country "TTO", :kind :product, :summary "Concentrated bitters based on gentian, herbs, and spices, produced by the House of Angostura; though originally developed in Venezuela, it has been manufactured in Trinidad since 1875 and remains a significant national export.", :url "https://en.wikipedia.org/wiki/Angostura_bitters", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "tto.craft.steelpan", :name "Steelpan", :country "TTO", :kind :craft, :summary "Percussion instrument made from steel drums, originating in Trinidad and Tobago and declared the country's national instrument in 1992.", :url "https://en.wikipedia.org/wiki/Steelpan", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "tto.festival.carnival", :name "Trinidad and Tobago Carnival", :country "TTO", :kind :festival, :summary "Annual event held on the Monday and Tuesday before Ash Wednesday, featuring colorful costumes, calypso and soca music, stick-fighting, limbo, and steelpan competitions, with roots dating to the 1780s.", :url "https://en.wikipedia.org/wiki/Trinidad_and_Tobago_Carnival", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "tto.heritage.pitch-lake", :name "Pitch Lake", :country "TTO", :kind :heritage, :summary "Largest natural deposit of bitumen in the world, estimated to contain 10 million tons, situated in southwest Trinidad and a significant natural resource and tourist destination.", :url "https://en.wikipedia.org/wiki/Pitch_Lake", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
